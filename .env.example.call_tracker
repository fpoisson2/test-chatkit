# ============================================================================
# CONFIGURATION POUR VOIR UNIQUEMENT LES LOGS D'APPELS
# ============================================================================
#
# Ajoutez cette ligne à votre fichier .env pour ne voir QUE les logs
# d'appels structurés (call_tracker) et masquer tous les autres logs.
#
# Valeurs acceptées: true, 1, yes (case insensitive)
# Par défaut: false (tous les logs sont affichés normalement)
#

CHATKIT_CALL_TRACKER_ONLY=true

# ============================================================================
# RÉSULTAT
# ============================================================================
#
# Avec cette configuration, vous ne verrez QUE:
#
# ================================================================================
# 📞 CONFIGURATION APPEL ENTRANT (call_id=xxx)
# ================================================================================
# 📍 Numéro entrant: 100
# 🤖 Modèle: gpt-realtime
# 🛠️  TOOLS CONFIGURÉS (3 tools):
#   1. [function] fetch_weather
#   2. [mcp] homeassistant
#       └─ Allowlist actif: 15 outils
#   3. [function] transfer_call
# ================================================================================
#
# ================================================================================
# ✅ SESSION VOCALE CRÉÉE AVEC SUCCÈS
# ================================================================================
# 🆔 Session ID: xxx
# 🌐 Serveurs MCP connectés: 2
#   1. homeassistant
#       └─ Allowlist actif: 15 outils
# ================================================================================
#
# ================================================================================
# ✅ APPEL ACCEPTÉ - EN ATTENTE DE MÉDIA ACTIF
# ================================================================================
# 📞 Call ID: xxx
# 📍 Depuis: 100
# 🗣️  Mode speak_first actif
# ================================================================================
#
# Tous les autres logs (PJSUA, httpcore, mcp, openai, uvicorn) seront masqués!
#
# ============================================================================
# POUR DÉSACTIVER
# ============================================================================
#
# Commentez la ligne ou mettez:
# CHATKIT_CALL_TRACKER_ONLY=false
#
